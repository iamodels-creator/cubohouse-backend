# ── SUPABASE ──────────────────────────────
# Obtenlos en: supabase.com → tu proyecto → Settings → API
SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── EMAIL (SMTP) ───────────────────────────
# Para Gmail: activa "Contrasenas de aplicacion" en tu cuenta Google
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=tucorreo@gmail.com
# SMTP_PASS=xxxx xxxx xxxx xxxx   ← contrasena de aplicacion (no la de tu cuenta)

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tucorreo@gmail.com
SMTP_PASS=tu_contrasena_de_aplicacion

# ── ADMIN ─────────────────────────────────
# Crea una clave secreta larga y aleatoria
ADMIN_SECRET=cambia_esto_por_algo_muy_largo_y_seguro_123

# ── SERVIDOR ──────────────────────────────
PORT=3000

# ── FRONTEND ──────────────────────────────
# URL de tu sitio (para CORS). En desarrollo usa *
FRONTEND_URL=https://tu-sitio.netlify.app
